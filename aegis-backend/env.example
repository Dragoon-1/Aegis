# ── Aegis Backend Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://aegis:change_me_strong_password@localhost/aegisdb

# ── AI Assistant (get from aistudio.google.com) ────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Environment ───────────────────────────────────────────────────────────────
# "development" enables hot reload and verbose logging
# "production"  disables hot reload, enables gzip, rate limiting
ENVIRONMENT=development

# ── Blockchain (Polygon) ─────────────────────────────────────────────────────
# Private key of the wallet that pays gas for reportThreat() calls
# Fund it with MATIC from https://faucet.polygon.technology (testnet)
POLYGON_PRIVATE_KEY=YOUR_POLYGON_PRIVATE_KEY
POLYGON_RPC_URL=YOUR_POLYGON_RPC_URL

# Contract address — fill in after running: cd aegis-contracts && npx hardhat deploy
CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS

# ── Reporting ─────────────────────────────────────────────────────────────────
REPORTS_DIR=/app/reports

# ── Police escalation thresholds ─────────────────────────────────────────────
POLICE_THRESHOLD=100
MASS_ATTACK_THRESHOLD=500
