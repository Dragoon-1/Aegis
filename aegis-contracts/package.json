{
  "name": "aegis-contracts",
  "version": "1.0.0",
  "description": "Aegis Threat Intelligence smart contracts — deployed on Polygon",
  "scripts": {
    "compile":       "hardhat compile",
    "test":          "hardhat test",
    "deploy:local":  "hardhat run scripts/deploy.js --network hardhat",
    "deploy:testnet":"hardhat run scripts/deploy.js --network amoy",
    "deploy:mainnet":"hardhat run scripts/deploy.js --network polygon",
    "node":          "hardhat node",
    "clean":         "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat":                           "^2.19.0",
    "dotenv":                            "^16.3.1"
  }
}
